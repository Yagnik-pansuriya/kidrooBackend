# === APPLICATION ===
NODE_ENV=production
PORT=5000

# === DATABASE ===
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/kidroo

# === SECURITY ===
# Comma-separated list of allowed origins for CORS
# Add your Vercel frontend URL here
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# === JWT Configuration ===
# IMPORTANT: Use a strong, unique secret in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-min-32-characters-long-change-this
JWT_EXPIRE=7d

# === CLOUDINARY (File Upload) ===
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === OPTIONAL ===
LOG_LEVEL=warn
REQUEST_TIMEOUT=30000

# === REDIS ===
REDIS_URL=redis://default:<REDIS_PASSWORD>@<REDIS_HOST>:<REDIS_PORT>

# === SMS Provider ===
# Use "twilio" to keep current Twilio flow, or "msg91" to send OTP via MSG91.
SMS_PROVIDER=twilio

# === TWILIO SMS ===
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# === MSG91 SMS ===
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=KIDROO
MSG91_ROUTE=4
MSG91_COUNTRY=91
# Optional DLT values if your MSG91 account/template requires them
MSG91_TEMPLATE_ID=
MSG91_ENTITY_ID=
